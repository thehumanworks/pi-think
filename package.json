{
  "name": "pi-think",
  "version": "0.1.0",
  "private": true,
  "description": "Pi Coding Agent extension that exposes a contained Pi SDK reasoning sub-agent as a think tool.",
  "bin": {
    "pi-think": "./cli.ts"
  },
  "type": "module",
  "scripts": {
    "build:cli": "mkdir -p dist && bun build ./cli.ts --compile --outfile dist/think",
    "install:cli": "bun run build:cli && mkdir -p \"$HOME/.local/bin\" && mv -f dist/think \"$HOME/.local/bin/think\""
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.1",
    "@earendil-works/pi-coding-agent": "^0.74.1",
    "@earendil-works/pi-tui": "^0.74.1"
  },
  "peerDependencies": {
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "trustedDependencies": [
    "koffi",
    "protobufjs"
  ]
}
